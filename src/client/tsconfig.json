{
  "compilerOptions": {
    "target": "ESNext",
    "sourceMap": true,
    "outDir": "../../public/scripts/",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "types": ["requirejs"],
    "strictNullChecks": true,
    "rootDir": "../"
  },
  "exclude": [
    "../../node_modules"
  ],
  "include": [
    "ts/**/*",
    "*.d.ts"
  ]
}
