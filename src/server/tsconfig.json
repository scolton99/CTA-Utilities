{
  "compilerOptions": {
    "module": "nodenext",
    "esModuleInterop": true,
    "target": "es6",
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "outDir": "../../dist",
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "lib": ["es2016"],
    "rootDir": "../"
  },
  "include": [
    "./**/*",
    ".eslintrc.js"
  ]
}