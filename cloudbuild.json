{
  "steps": [
    {
      "name": "gcr.io/cloud-builders/gcloud",
      "args": ["storage", "cp", "gs://cta-backend/private/app.yaml", "app.yaml"]
    },
    {
      "name": "node:lts",
      "entrypoint": "npm",
      "args": ["install"]
    },
    {
      "name": "node:lts",
      "entrypoint": "npm",
      "args": ["run", "gcp-build"]
    },
    {
      "name": "gcr.io/cloud-builders/gcloud",
      "args": ["app", "deploy"],
      "timeout": "600s"
    }
  ]
}
